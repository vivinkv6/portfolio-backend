{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "short_description": {
      "type": "text"
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "banner_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "is_section": {
      "type": "boolean",
      "default": false
    },
    "content": {
      "type": "customField",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_section"
            },
            false
          ]
        }
      },
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "sections": {
      "type": "component",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "is_section"
            },
            true
          ]
        }
      },
      "component": "blog.section",
      "repeatable": true
    },
    "published_date": {
      "type": "date"
    },
    "seo": {
      "type": "component",
      "component": "common.seo",
      "repeatable": false
    },
    "tags": {
      "type": "customField",
      "customField": "global::tags"
    }
  }
}
