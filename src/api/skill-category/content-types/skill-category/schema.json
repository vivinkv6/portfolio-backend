{
  "kind": "collectionType",
  "collectionName": "skill_categories",
  "info": {
    "singularName": "skill-category",
    "pluralName": "skill-categories",
    "displayName": "Skill Category"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "unique": true
    },
    "skills": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::skill.skill",
      "mappedBy": "skill_category"
    },
    "priority": {
      "type": "integer"
    }
  }
}
